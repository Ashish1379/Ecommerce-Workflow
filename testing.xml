<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="E-Commerce WorkFlow" verbose="1">

	<listeners>
		<listener class-name="listeners.TestListener" />
	</listeners>

	 <!-- Edge Tests  -->
    <test name="EdgeTests">
        <parameter name="browser" value="edge" />
        <classes>
            <class name="tests.TestLandingPage"/>
            <class name="tests.TestLoginPage"/>
            <class name="tests.TestHomePage"/>
            <class name="tests.TestCategoryPage"/>
            <class name="tests.TestProductListPage"/>
            <class name="tests.TestProductPage"/>
            <class name="tests.TestCartPage"/>
            <class name="tests.TestCheckoutPage"/>
        </classes>
    </test>
    

	<!--Chrome Tests  -->
	<test name="ChromeTests">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="tests.TestLandingPage" />
			<class name="tests.TestLoginPage" />
			<class name="tests.TestHomePage" />
			<class name="tests.TestCategoryPage" />
			<class name="tests.TestProductListPage" />
			<class name="tests.TestProductPage" />
			<class name="tests.TestCartPage" />
			<class name="tests.TestCheckoutPage" />
			 <!-- -->

		</classes>
	</test>
</suite>